# Admin auth (single user)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# 32+ char random; used to sign session cookie
SESSION_SECRET=change-me-to-a-long-random-string-please-32

# MongoDB (shared with desktop app)
MONGODB_URI=mongodb://localhost:27017/utter

# Backblaze B2 (shared with desktop app). S3-compatible storage.
# B2_REGION: the region shown on your B2 bucket page, e.g. us-west-004
# R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY: the B2 application key ID and key
B2_REGION=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=utter

# Google Gemini (free — get key at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Optional: only needed for /api/recordings/:id/retranscribe in the web app.
# Primary transcription path runs in the desktop app.
GROQ_API_KEY=
