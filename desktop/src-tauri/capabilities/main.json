{
  "$schema": "https://schema.tauri.app/config/2.0",
  "identifier": "main",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "global-shortcut:default",
    "dialog:default",
    "shell:default",
    {
      "identifier": "shell:allow-open",
      "allow": [{ "url": "https://**" }, { "url": "http://**" }]
    }
  ]
}
