# Same admin used by the web app
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Mongo (shared with web)
MONGODB_URI=mongodb://localhost:27017/utter

# R2 (shared with web)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=utter

# Groq for transcription (desktop only)
GROQ_API_KEY=

# Where the Next.js web app is reachable. Used when you click a recent
# recording in the desktop app — it opens this URL + /r/<id> in your browser.
# Defaults to http://localhost:3000 if not set.
WEB_APP_URL=http://localhost:3000
